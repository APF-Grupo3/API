# Variables de entorno de FundCompare
# Copia este archivo como .env y rellena los valores reales
# NUNCA subas .env al repositorio

# ── Telegram ──────────────────────────────────────────────────────────────────
# Token del bot obtenido de @BotFather en Telegram
TELEGRAM_BOT_TOKEN=REEMPLAZAR_CON_TOKEN_DEL_BOT

# ID del chat (personal o grupo) al que el bot enviará mensajes
# Ejemplo personal: 123456789
# Ejemplo grupo:   -1001234567890
TELEGRAM_CHAT_ID=REEMPLAZAR_CON_CHAT_ID

# ── Flask (opcional) ──────────────────────────────────────────────────────────
# Clave secreta para sesiones Flask (si se activa autenticación en fases futuras)
SECRET_KEY=cambia_esto_por_un_valor_seguro

# ── Base de datos (reservado para fase posterior) ─────────────────────────────
# DATABASE_URL=sqlite:///app.db
