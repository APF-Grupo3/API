# Creación de base de datos de solicitudes
class Transaction(db.Model):
    """Modelo de Solicitudes de información

    Atributos clave:
        usuario_id: FK a usuario
        ticker1: nombre ticker 1
        ticker2: nombre ticker 2
        fecha_desde : fecha inicio comparación
        fecha_hasta : fecha final de comparación
        metadata: JSON para datos adicionales flexibles
    """
    __tablename__ = 'solicitudes'

    id = db.Column(db.Integer, primary_key=True)
    usuario_id = db.Column(db.Integer, db.ForeignKey('usuarios.id'), nullable=False)

    # Fechas
    fecha_desde = db.Column(db.DateTime, default=datetime.utcnow)
    fecha_hasta = db.Column(db.DateTime, default=datetime.utcnow)

    # Metadata flexible (JSON)
    metadata = db.Column(db.JSON)

    created_at = db.Column(db.DateTime, default=datetime.utcnow)
    updated_at = db.Column(db.DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)

    # Relación con auditoría
    audit_logs = db.relationship('AuditLog', backref='transaction', lazy=True)

    def to_dict(self):
        """Serialización a JSON

        Incluye datos relacionados del cliente para evitar
        múltiples queries (optimización N+1)
        """
        return {
            'id': self.id,
            'usuario_id': self.usuario_id,
            'usuario_email': self.usuario.email if self.usuario else None,
            'usuario_nombre': self.usuario.nombre if self.usuario else None,
            'usuario_apellido': self.usuario.apellido if self.usuario else None,
            'usuario_telefono': self.usuario.telefono if self.usuario else None,
            'start_date': self.fecha_desde.isoformat() if self.fecha_desde else None,
            'end_date': self.fecha_completado.isoformat() if self.fecha_completado else None,
            'metadata': self.metadata,
            'created_at': self.created_at.isoformat() if self.created_at else None
        }

print("✓ Modelo Transaction definido correctamente")